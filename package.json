{
  "name": "arabalariseviyoruz",
  "version": "1.0.0",
  "description": "Türkiye'nin araba topluluğu platformu",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node scripts/migrate.js",
    "dev:legacy": "nodemon src/app.js",
    "start:legacy": "node src/app.js",
    "dev:api": "npm run dev -w @berra/api",
    "dev:web": "npm run dev -w @berra/web",
    "build:api": "npm run build -w @berra/api",
    "build:web": "npm run build -w @berra/web"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "sanitize-html": "^2.17.2",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
